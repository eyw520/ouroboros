#!/usr/bin/env bash
#
# secret-scan — block credentials from entering the repo. Greps for secret
# VALUE patterns (length-anchored, so doc placeholders like "sk-ant-api…" or
# "xoxb-…" don't trip them) and exits non-zero on a hit, printing file:line
# with the value REDACTED, so the hook output never re-leaks the secret.
#
# Modes:
#   (no args)        scan STAGED content (`git diff --cached`) — the
#                    .githooks/pre-commit gate. Real env files are gitignored,
#                    so they are never staged and never scanned.
#   --tracked        scan every tracked file — full-tree sweep (doctor/audit).
#   <file> [file…]   scan those work-tree files.
#
# This file is the repo's own copy — extend PATTERNS or exemptions here.
set -uo pipefail

# Credential value patterns, anchored to real lengths (NOT doc placeholders):
#   private key blocks (PEM)          sk-ant-…  Anthropic    sk-proj-…  OpenAI
#   xox[baprs]-/xapp-  Slack          gh*_/github_pat_  GitHub    npm_…  npm
#   AKIA…  AWS access key id          <digits>:<35+>  Telegram bot token
#   AIza…  Google API key             [sr]k_live_…  Stripe    hf_…  Hugging Face
# Slack tokens require a digit segment (placeholders like xoxb-your-bot-token
# have none); Telegram tokens require a non-alphanumeric left boundary (URL
# slugs embed digit:slug runs mid-word).
PATTERNS='-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----|sk-ant-[A-Za-z0-9._-]{24,}|sk-proj-[A-Za-z0-9_-]{40,}|xox[baprs]-[0-9]{8,}-[0-9A-Za-z-]{12,}|xapp-[0-9]-[0-9A-Za-z-]{12,}|gh[opsu]_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{30,}|npm_[A-Za-z0-9]{36}|AKIA[0-9A-Z]{16}|(^|[^0-9A-Za-z])[0-9]{6,12}:[A-Za-z0-9_-]{35,}|AIza[0-9A-Za-z_-]{35}|[sr]k_live_[0-9A-Za-z]{24,}|hf_[A-Za-z0-9]{30,}'

# A malformed pattern must fail LOUDLY: a grep error inside the scan loop would
# otherwise read as "no match" and wave real secrets through.
printf 'x' | grep -qE -e "$PATTERNS"
rc=$?
if [ "$rc" -gt 1 ]; then
  echo "secret-scan: PATTERNS failed to compile (grep exit $rc) — refusing to pass" >&2
  exit 2
fi

# Paths never scanned: test trees carry FAKE-but-realistic secrets by design,
# and this scanner itself embeds credential-shaped patterns. Real secrets never
# belong in test code; everything that matters lives outside these paths.
is_exempt() {
  case "$1" in
    tests/*|*/tests/*|*/fixtures/*|.githooks/secret-scan) return 0 ;;
    *) return 1 ;;
  esac
}

# Content to scan: the staged blob in hook mode, the work-tree file otherwise.
emit() { # $1=file $2=mode
  if [ "$2" = staged ]; then git show ":$1" 2>/dev/null; else cat "$1" 2>/dev/null; fi
}

mode=staged
files=()
if [ "${1:-}" = "--tracked" ]; then
  mode=files
  while IFS= read -r f; do [ -n "$f" ] && files+=("$f"); done < <(git ls-files)
elif [ "$#" -gt 0 ]; then
  mode=files; files=("$@")
else
  while IFS= read -r f; do [ -n "$f" ] && files+=("$f"); done \
    < <(git diff --cached --name-only --diff-filter=ACM)
fi

hits=0
for f in "${files[@]:-}"; do
  [ -n "$f" ] || continue
  is_exempt "$f" && continue
  match="$(emit "$f" "$mode" | grep -naE -e "$PATTERNS" || true)"
  [ -n "$match" ] || continue
  [ "$hits" -eq 0 ] && printf 'xx secret-scan: possible credential(s) in committed content:\n' >&2
  hits=1
  # file:line only — the matched VALUE is deliberately discarded
  printf '%s\n' "$match" | while IFS=: read -r ln _; do
    printf '   %s:%s  (value redacted)\n' "$f" "$ln" >&2
  done
done

if [ "$hits" -ne 0 ]; then
  printf '   Secrets belong in a gitignored env file, never a tracked file.\n' >&2
  printf '   False positive? exempt the path in .githooks/secret-scan, or (last resort) commit --no-verify.\n' >&2
  exit 1
fi
exit 0
